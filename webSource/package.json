{
    "name": "blog-platform",
    "private": true,
    "scripts": {
        "dev:admin": "pnpm --filter @blog/admin dev",
        "dev:blog": "pnpm --filter @blog/web dev",
        "dev:frontend": "concurrently \"pnpm dev:admin\" \"pnpm dev:blog\"",
        "build:shared": "pnpm --filter @blog/shared build",
        "build:admin": "pnpm --filter @blog/admin build",
        "build:blog": "pnpm --filter @blog/web build",
        "build:server": "cd ../server && go build -o ../web/server/blog-server .",
        "build": "pnpm build:shared && pnpm build:admin && pnpm build:blog && pnpm build:server && cp ../server/config/config.yaml ../web/server/config.yaml",
        "clean": "rm -rf ../web",
        "lint": "pnpm -r lint",
        "format": "prettier --write \"**/*.{ts,tsx,json,css}\""
    },
    "devDependencies": {
        "concurrently": "^9.1.0",
        "prettier": "^3.4.0",
        "typescript": "^5.7.0"
    }
}